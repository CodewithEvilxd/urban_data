DATABASE_URL=postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require
CORS_ORIGINS=http://localhost:3000
NOMINATIM_USER_AGENT=UrbanCoolHackathon/1.0 (contact: your-email@example.com)
NOMINATIM_EMAIL=your-email@example.com
DATA_BACKEND=json
GITHUB_REPOSITORY=owner/repo
GIT_BRANCH=main
PUSH_CHANGES=true
RETRAIN_MODEL=true
SKIP_SEED=true
INCLUDE_RASTERS=false
AUTOMATION_TIMEOUT_SECONDS=7200
AUTOMATION_SECRET=replace-with-long-random-secret
GITHUB_TOKEN=replace-with-github-token
